# CrypticQuest backend — environment template.
# Copy to .env and fill in. .env is gitignored; .env.example is committed.
# Values below are PRODUCTION-oriented (behind an HTTPS reverse proxy). For local
# dev the code defaults already work, so you usually run without a .env at all.

# --- Networking -------------------------------------------------------------
# Port the server listens on inside the container (compose maps it to the host).
PORT=8080

# The single browser origin allowed by CORS — your deployed frontend. Must be an
# exact origin (scheme + host + optional port), never "*". This is the Netlify
# site in prod; locally the code defaults to http://localhost:5173.
ALLOWED_ORIGIN=https://your-app.netlify.app

# --- Session cookie ---------------------------------------------------------
# Frontend (Netlify) and backend (VPS) are different sites, so the session cookie
# is cross-site: SameSite=None REQUIRES Secure=true (HTTPS), which the reverse
# proxy terminates. Use these two together in prod.
COOKIE_SECURE=true
COOKIE_SAMESITE=None
# Leave empty for a host-only cookie (the usual choice). Set only if you serve the
# API from a subdomain and need the cookie shared across subdomains.
COOKIE_DOMAIN=

# --- First-admin bootstrap --------------------------------------------------
# On first start, if no admin exists, one is created from these. Pick a strong
# password and rotate/clear after the first boot. Leave both empty to skip.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- Storage (image defaults; override only if you change the layout) -------
# DB lives on the /data volume; files/ is baked into the image.
# DB_PATH=/data/ctf.db
# FILES_DIR=/app/files
