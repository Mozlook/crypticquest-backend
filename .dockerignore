# Keep the build context small and free of local/runtime cruft.
.git
.gitignore
README.md
Dockerfile
.dockerignore

# Gated content files are never part of the image — they're bind-mounted at
# runtime and must not leak into the built image.
files/

# Local databases (the prod DB lives in the /data volume).
*.db
*.db-wal
*.db-shm

# Local env files.
.env
.env.local
*.local.env

# OS / editor cruft.
.DS_Store
*.swp
